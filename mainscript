-- === FUNCIÓN DE ATAQUE ===
local lastAttack = 0

local function performAttack()
    local now = tick()
    if now - lastAttack < 0.1 then return end
    lastAttack = now

    local rootPart = character:FindFirstChild("HumanoidRootPart")
    if not rootPart then return end

    for _, otherChar in pairs(workspace:GetChildren()) do
        if otherChar ~= character
            and otherChar:FindFirstChild("Humanoid")
            and otherChar:FindFirstChild("HumanoidRootPart") then

            local dist = (rootPart.Position - otherChar.HumanoidRootPart.Position).Magnitude
            if dist <= stats.attackRange then
                print("Hit!", otherChar.Name, "| Distancia:", math.floor(dist), "studs")
            end
        end
    end
end

